# Application Configuration
PROJECT_NAME="FinanceAI Copilot"
API_V1_STR="/api/v1"
SECRET_KEY="" # REQUIRED: Generate a strong secret key (e.g. openssl rand -hex 32)
ACCESS_TOKEN_EXPIRE_MINUTES=11520
BACKEND_CORS_ORIGINS="http://localhost:3000"

# Database Settings
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance_ai_db
POSTGRES_PORT=5432

# Centralized Storage Path (defaults to /app/storage inside Docker container)
STORAGE_DIR="/app/storage"

# LLM Keys
GROQ_API_KEY=""
GROQ_MODEL="llama3-8b-8192"
